# ==========================================
# StockAgent 环境配置示例
# 
# 使用方法:
#   1. 复制此文件为 .env
#   2. 根据实际情况修改配置值
#   3. 敏感信息请勿提交到版本控制
# ==========================================

# ==================== 基础配置 ====================

DEBUG=false
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ==================== 节点配置 ====================

# 节点类型: web, data_sync, mcp, inference, listener
NODE_TYPE=web
# 节点 ID (可选，不填则自动生成)
# NODE_ID=web-node-1
NODE_HEARTBEAT_INTERVAL=10
NODE_TTL=30

# ==================== Web 服务配置 ====================

WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_WORKERS=1
WEB_RELOAD=true

# ==================== Redis 配置 ====================

REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_MAX_CONNECTIONS=100

# 队列配置 (通常无需修改)
REDIS_TASK_QUEUE=agent:tasks
REDIS_RESULT_CHANNEL_PREFIX=agent:results
REDIS_NODE_REGISTRY_PREFIX=agent:nodes

# ==================== MongoDB 配置 ====================

MONGO_HOST=localhost
MONGO_PORT=27017
# MONGO_USERNAME=admin
# MONGO_PASSWORD=your-mongo-password
MONGO_DATABASE=stock_agent
MONGO_AUTH_SOURCE=admin
MONGO_MAX_POOL_SIZE=50

# ==================== Milvus 向量数据库配置 ====================

MILVUS_HOST=localhost
MILVUS_PORT=19530
# MILVUS_USER=root
# MILVUS_PASSWORD=your-milvus-password
MILVUS_RESEARCH_REPORTS_COLLECTION=research_reports
MILVUS_MARKET_SNIPPETS_COLLECTION=market_snippets
MILVUS_EMBEDDING_DIM=1024

# ==================== Tushare 数据源配置 ====================

# 必须! 请在 https://tushare.pro 注册获取 Token
TUSHARE_TOKEN=your-tushare-pro-token
TUSHARE_RATE_LIMIT=200
TUSHARE_BATCH_SIZE=100

# ==================== LLM 模型配置 ====================

# 模型提供商: openai, dashscope (阿里), deepseek, zhipu, ollama
LLM_PROVIDER=dashscope

# 阿里云 DashScope (推荐国内使用)
LLM_API_KEY=your-dashscope-api-key
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_EMBEDDING_MODEL=text-embedding-v3

# DeepSeek (如果使用)
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-your-deepseek-api-key
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL_NAME=deepseek-chat
# LLM_EMBEDDING_MODEL=deepseek-embedding

# OpenAI (如果使用)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-openai-api-key
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o
# LLM_EMBEDDING_MODEL=text-embedding-3-small

# 智谱 AI (如果使用)
# LLM_PROVIDER=zhipu
# LLM_API_KEY=your-zhipu-api-key
# LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL_NAME=glm-4-plus
# LLM_EMBEDDING_MODEL=embedding-3

# Ollama 本地模型 (如果使用)
# LLM_PROVIDER=ollama
# LLM_API_BASE=http://localhost:11434/v1
# LLM_MODEL_NAME=qwen2.5:14b

# 模型参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_MAX_CONCURRENT_REQUESTS=10

# ==================== 数据同步配置 ====================

# 采集调度时间 (cron 表达式: 分 时 日 月 周)
# 不填则使用默认值

# 股票基础信息采集 (默认: 每个交易日 9:00)
# SYNC_STOCK_BASIC_SCHEDULE=0 9 * * 1-5

# 股票日线数据采集 (默认: 每个交易日 15:30)
# SYNC_STOCK_DAILY_SCHEDULE=30 15 * * 1-5

# 指数基础信息采集 (默认: 每个交易日 9:00)
# SYNC_INDEX_BASIC_SCHEDULE=0 9 * * 1-5

# 指数日线数据采集 (默认: 每个交易日 15:35)
# SYNC_INDEX_DAILY_SCHEDULE=35 15 * * 1-5

# 行业资金流向采集 (默认: 每个交易日 16:00)
# SYNC_MONEYFLOW_INDUSTRY_SCHEDULE=0 16 * * 1-5

# 概念板块资金流向采集 (默认: 每个交易日 16:05)
# SYNC_MONEYFLOW_CONCEPT_SCHEDULE=5 16 * * 1-5

# 涨跌停数据采集 (默认: 每个交易日 16:10)
# SYNC_LIMIT_LIST_SCHEDULE=10 16 * * 1-5

# 每日统计数据计算 (默认: 每个交易日 16:30，确保其他数据已同步)
# SYNC_DAILY_STATS_SCHEDULE=30 16 * * 1-5

# 新闻采集 (默认: 每 2 小时)
# SYNC_NEWS_SCHEDULE=0 */2 * * *

# ==================== 可观测性配置 ====================

# 日志级别: DEBUG, INFO, WARNING, ERROR
OBS_LOG_LEVEL=INFO

# 日志文件配置
OBS_LOG_TO_FILE=true
OBS_LOG_DIR=logs
OBS_LOG_MAX_SIZE_MB=50
OBS_LOG_BACKUP_COUNT=10

# Loki 日志收集 (可选)
OBS_LOKI_ENABLED=false
# OBS_LOKI_URL=http://localhost:3100/loki/api/v1/push

# Arize Phoenix 追踪 (可选)
OBS_PHOENIX_ENABLED=false
OBS_PHOENIX_PROJECT=stock-agent

# ==================== Listener 节点配置 ====================

# 轮询间隔 (秒)
LISTENER_POLL_INTERVAL=60

# 每日涨跌停数据获取时间 (格式: HH:MM)
LISTENER_LIMIT_FETCH_TIME=09:15

# 交易时间配置 (格式: HH:MM-HH:MM)
LISTENER_MORNING_SESSION=09:30-11:30
LISTENER_AFTERNOON_SESSION=13:00-15:00

# 非交易时间是否静默
LISTENER_SILENT_OUTSIDE_TRADING=true

# ==================== 通知配置 ====================

# 企业微信 Webhook URL
# 获取方式: 企业微信 -> 群设置 -> 群机器人 -> 添加 -> 复制 Webhook 地址
# NOTIFY_WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# 是否启用通知
NOTIFY_ENABLED=true

# 消息发送最小间隔 (秒，防止刷屏)
NOTIFY_MIN_INTERVAL=10

# ==================== RPC 配置 ====================

# 各节点 gRPC 端口
RPC_WEB_PORT=50051
RPC_INFERENCE_PORT=50052
RPC_LISTENER_PORT=50053
RPC_DATA_SYNC_PORT=50054
RPC_MCP_PORT=50055

# RPC 超时 (秒)
RPC_TIMEOUT=10.0

# RPC 重试次数
RPC_MAX_RETRIES=3

# ============ Embedding 单独配置 ============
# 因为 DeepSeek 不支持 Embedding API，使用 DashScope

# Embedding Provider (openai/dashscope/zhipu/ollama)
LLM_EMBEDDING_PROVIDER=dashscope

# DashScope API Key (阿里云)
LLM_EMBEDDING_API_KEY=你的阿里云DashScope API Key

# Embedding 模型 (DashScope 的 text-embedding-v3)
LLM_EMBEDDING_MODEL=text-embedding-v3